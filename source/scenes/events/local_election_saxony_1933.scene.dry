    image.src = "img/redthuringia.png";  

    cardEl.appendChild(image);  
    var contentDiv = document.querySelector("#page #mid_panel #content");
    contentDiv.appendChild(cardEl);
!}

놀랍게도, [? if president_ideology != "Left" and not presidential_powers: 연정이 형성될 경우 <span style="color: #808080;">반동적</span> 성향의 대통령이 <i>제국행정집행</i>을 명령할 것이라는 두려움 때문에 양측 모두 꺼려했음에도 불구하고, ?]<span style="color: #c00000;">붉은</span> 작센이 부활했습니다!

[? if (president_ideology == "Moderate" or president == "Hindenburg") and not presidential_powers: 독일에서 가장 좌파적이고 산업화된 주 중 하나로서, 우리는 우리의 영향력을 발휘하여 포괄적인 개혁을 시행하고 작센을 <span style="color: #c00000;">사회주의</span>의 보루로 탈바꿈시킬 것입니다. 대통령의 인내심이 매우 한계에 다다랐으니, 신중히 행동하십시오. ?]
[? if president_ideology == "Left" or presidential_powers: 독일에서 가장 좌파적이고 산업화된 주 중 하나로서, 우리는 우리의 영향력을 발휘하여 포괄적인 개혁을 시행하고 작센을 <span style="color: #c00000;">사회주의</span>의 보루로 탈바꿈시킬 것입니다. 하지만 극우 쿠데타 시도에 대한 소문이 무성해지고 있습니다. 신중히 행동하십시오. ?]

@president_nope

- @joever
@joever
title: [+ president +] 대통령은 즉각 작센 정부에 대한 <i>제국행정집행</i>을 명령했습니다.  
